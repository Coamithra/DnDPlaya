# Anthropic API key (required)
ANTHROPIC_API_KEY=

# Model to use for all agents — accepts aliases: haiku, sonnet, opus
# or full IDs like claude-haiku-4-5-20251001 (default: haiku)
DNDPLAYA_MODEL=haiku

# Max tokens per agent response (default: 1024)
DNDPLAYA_MAX_TOKENS=1024

# Party level (default: 3)
DNDPLAYA_PARTY_LEVEL=3
